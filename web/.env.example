DATABASE_URL="postgresql://postgres.[PROJECT_REF]:[PASSWORD]@[REGION].pooler.supabase.com:5432/postgres"
DIRECT_URL="postgresql://postgres.[PROJECT_REF]:[PASSWORD]@[REGION].pooler.supabase.com:5432/postgres"


AUTH_SECRET=""
AUTH_GITHUB_ID=""
AUTH_GITHUB_SECRET=""
ADMIN_EMAILS="you@example.com"

APP_ENCRYPTION_KEY=""
NEXT_PUBLIC_SITE_URL="http://127.0.0.1:3000"

OPENAI_API_KEY=""
SUPABASE_ASSETS_BUCKET="obsidian-assets"

# Optional paid/advanced adapters.
QDRANT_URL=""
QDRANT_API_KEY=""
QDRANT_COLLECTION="pkb_knowledge"
BLOB_READ_WRITE_TOKEN=""

GITEE_DEFAULT_REPO_URL="https://gitee.com/fjw08/obsidian"
GITEE_DEFAULT_BRANCH="master"

# Vercel Cron sends Authorization: Bearer $CRON_SECRET when this variable is set.
CRON_SECRET=""
SYNC_CRON_SECRET=""

# `vault` keeps local file preview; `database` forces Supabase content reads in local dev.
CONTENT_SOURCE="vault"

# Local preview fallback. Production syncs from Gitee into Supabase.
OBSIDIAN_VAULT_PATH="../obsidian"
